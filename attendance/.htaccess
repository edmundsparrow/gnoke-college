Options -Indexes
RewriteEngine On

# Remove trailing slash redirect (optional, keeps URLs consistent)
# RewriteRule ^(.*)/$ /$1 [R=301,L]

# Serve folder index.html files cleanly (already handled by DirectoryIndex)
DirectoryIndex index.html

# If someone tries to access attendance1.html etc. directly, redirect to clean URL
RewriteRule ^attendance1\.html$ /ledger/ [R=301,L]
RewriteRule ^attendance2\.html$ /register/ [R=301,L]
RewriteRule ^attendance3\.html$ /analysis/ [R=301,L]
RewriteRule ^attendance4\.html$ /sessions/ [R=301,L]
